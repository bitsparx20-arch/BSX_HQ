# Copy to backend/.env for local development

MONGO_URL=mongodb://127.0.0.1:27017
DB_NAME=bitsparx_hq
JWT_SECRET=change-me-local-dev-secret

# PinBot WhatsApp templates
PINBOT_API_KEY=your-pinbot-api-key
PINBOT_PHONE_NUMBER_ID=1103797126158774
PINBOT_TEMPLATE_NAME=lms_notification
# Attendance check-in: Checked in by {{1}}, Time: {{2}}, footer Team Bitsparx
PINBOT_ATTENDANCE_TEMPLATE=bitsparx_attendence
PINBOT_MEETING_TEMPLATE=bitsparx_meeting
# Also notify admin phones on employee check-in (true/false)
PINBOT_ATTENDANCE_NOTIFY_ADMINS=true

# Legacy SpringEdge text API (optional fallback if PinBot not set)
SPRINGEDGE_API_KEY=
SPRINGEDGE_ENABLED=false
SPRINGEDGE_SENDER=BITSPARX

# PDF blob storage (local filesystem; override path for production volume)
BLOB_STORAGE_PATH=

ADMIN_EMAIL=admin@bitsparx.com
ADMIN_PASSWORD=Admin@123
ADMIN_PHONE=919999999999
