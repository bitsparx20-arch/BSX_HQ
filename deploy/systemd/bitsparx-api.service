[Unit]
Description=Bitsparx HQ API
After=network.target docker.service
Wants=docker.service

[Service]
Type=simple
User=root
WorkingDirectory=/opt/bitsparx-hq/backend
EnvironmentFile=/etc/bitsparx-hq.env
ExecStart=/opt/bitsparx-hq/backend/.venv/bin/uvicorn server:app --host 127.0.0.1 --port 8000
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
