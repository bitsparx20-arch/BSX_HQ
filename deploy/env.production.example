# Copy to server: /etc/bitsparx-hq.env

MONGO_URL=mongodb://127.0.0.1:27017
DB_NAME=bitsparx_hq
JWT_SECRET=generate-a-long-random-secret
# Use your domain when configured (comma-separated if multiple)
CORS_ORIGINS=https://hq.yourdomain.com,http://147.93.104.138
COOKIE_SECURE=true
APP_DOMAIN=hq.yourdomain.com

LLM_PROVIDER=bedrock
AWS_REGION=ap-south-1
BEDROCK_MODEL_ID=apac.amazon.nova-micro-v1:0
BEDROCK_API_KEY=

ADMIN_EMAIL=admin@bitsparx.com
ADMIN_PASSWORD=change-this-password
